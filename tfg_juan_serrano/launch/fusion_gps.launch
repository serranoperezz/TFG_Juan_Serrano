<?xml version="1.0"?>
<launch>
  <arg name="wait_for_datum" default="false" />  <!-- false: (0,0) en la primera señal gps recibida, true: en las coordenadas de datum-->


  <!-- El filtro de Kalman -->
  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se" clear_params="true" output="screen">
    <rosparam command="load" file="$(find tfg_juan_serrano)/config/ekf_fusion.yaml" />
    <remap from="odometry/filtered" to="odometry/filtered_map"/>
  </node>

  <!-- Traduce de coordenadas terrestres (Latitud y Longitud) provinientes del gps, a coordenadas cartesianas (x,y) -->
  <node pkg="robot_localization" type="navsat_transform_node" name="navsat_transform" clear_params="true" output="screen">
    <remap from="imu/data" to="/imu/data" />
    <remap from="gps/fix" to="/ublox_gps/fix" />
    <remap from="odometry/filtered" to="odometry/filtered_map"/>

    <rosparam param="datum">[36.715611, -4.490861, 0.0]</rosparam>

    <param name="magnetic_declination_radians" value="0"/>
    <param name="yaw_offset" value="1.5707963"/>  <!-- Corrige el norte sumando 90º al estandar de ROS que apunta al este-->
    <param name="zero_altitude" value="true"/>
    <param name="broadcast_cartesian_transform" value="false"/> 
    
    <param name="publish_filtered_gps" value="true"/>

    <param name="wait_for_datum" value="$(arg wait_for_datum)"/>
  </node>


  <!-- Dibuja la trayectoria en rviz -->
  <node pkg="hector_trajectory_server" type="hector_trajectory_server" name="trajectory_server_tfg" output="log">
    <param name="target_frame_name" value="odom" />
    <param name="source_frame_name" value="base_link" />
    <param name="trajectory_update_rate" value="10.0" />
    <param name="trajectory_publish_rate" value="10.0" />
  </node>

</launch>